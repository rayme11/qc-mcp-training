# .env - Environment Variables for MCP Project

# OpenAI API Key (for LLM integration)
OPENAI_API_KEY=
# How to get: Sign up at https://platform.openai.com/, go to 'API Keys', create a new key, and paste it here.

# Ollama API URL (for local LLM integration, optional)
OLLAMA_API_URL=http://localhost:11434
# How to get: Install Ollama locally (https://ollama.com/), start the server, and use the default URL above.

# MCP Server Host and Port
MCP_SERVER_HOST=localhost
MCP_SERVER_PORT=8000

# (Add more variables as needed for future integrations)

# Usage:
# - Copy this file to .env in your project root.
# - Fill in the values as needed.
# - Variables will be loaded automatically by Python dotenv or FastAPI.
